      "Agent",
      "TaskCreate",
      "TaskList",
      "TaskUpdate",
      "TaskGet",
      "TaskStop",
      "TaskOutput",
      "AskUserQuestion",
      "Skill",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
