      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(pip3:*)",
      "Bash(bash:*)",
      "Bash(supabase:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(open:*)",
      "Bash(test:*)",
      "Bash(diff:*)",
      "Bash(~/bin/zao-tracker:*)",
      "Bash(~/bin/zao-secrets:*)",
      "Bash(~/bin/zao-pr-task:*)",
      "Bash(~/bin/zao-fetch-reddit.sh:*)",
      "Bash(~/bin/zao-fetch-x.sh:*)",
      "Bash(~/bin/safe-git-push.sh:*)",
      "Bash(ssh root@187.77.3.104*)",
      "Bash(ssh root@31.97.148.88*)",
      "Bash(scp * root@187.77.3.104:*)",
      "Bash(scp * root@31.97.148.88:*)",
      "Bash(systemctl --user *)",
      "mcp__playwright__*",
      "mcp__context7__*",
      "mcp__grep__searchGitHub",
      "mcp__serena__*",
      "mcp__plugin_everything-claude-code_exa__*",
      "mcp__plugin_everything-claude-code_github__*",
      "mcp__plugin_everything-claude-code_memory__*",
      "mcp__plugin_everything-claude-code_sequential-thinking__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Google_Drive__*"
    ],
    "deny": [
      "Bash(git push --force*main*)",
      "Bash(git push --force-with-lease*main*)",
      "Bash(git push origin main*)",
      "Bash(git push main*)",
      "Bash(git reset --hard origin/main*)",
      "Bash(git branch -D main*)",
      "Bash(rm -rf /Users/*)",
      "Bash(rm -rf /Users/zaalpanthaki/Documents/*)",
      "Bash(rm -rf /Users/zaalpanthaki/.claude/*)",
      "Bash(rm -rf /Users/zaalpanthaki/.zao/*)",
      "Bash(rm -rf .git*)",
      "Bash(supabase db reset*)",
      "Bash(supabase migrate down*)",
      "Bash(curl*-X DELETE*)",
      "Bash(curl*--request DELETE*)",
      "Bash(docker system prune*--volumes*)",
      "Bash(docker volume rm *)",
      "Bash(npm publish*)",
      "Bash(gh repo delete*)",
      "Bash(gh release delete*)",
      "Write(.env*)",
      "Edit(.env*)",
      "Write(~/.zao/zao.env)",
      "Edit(~/.zao/zao.env)",
      "Bash(cat ~/.zao/zao.env*)",
      "Bash(cat .env*)",
      "Bash(grep*.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__serena__*",
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks auto-approve --client=claude-code"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$PROJECT_DIR\" && STAGED=$(git diff --cached --name-only --diff-filter=d | grep -E '\\.(ts|tsx)$' | tr '\\n' ' '); if [ -n \"$STAGED\" ]; then npx eslint --max-warnings 10 $STAGED 2>&1 | tail -20; fi",
            "statusMessage": "Linting staged files..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$PROJECT_DIR\" && bash .claude/skills/worksession/branch-guard.sh",
            "statusMessage": "Checking branch safety..."
          },
          {
            "type": "command",
            "command": "cd \"$PROJECT_DIR\" && npm run typecheck 2>&1 | tail -10",
            "statusMessage": "Typechecking before push..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "prompt",
            "if": "Write(research/*)",
            "prompt": "A research document was just written. Score it against this 8-point checklist (1 point each):\n1. Recommendations/key decisions at the TOP (table or bullet list before body)\n2. ZAO OS-specific (references Next.js 16, Supabase, Farcaster, 100-member community, or codebase paths)\n3. Numbers, versions, and dates included (not vague 'recently' or 'many')\n4. Sources linked at bottom with URLs\n5. Cross-referenced with existing research docs or codebase state\n6. Actionable (tells you what to DO, not just what exists)\n7. Open-source code searched (mentions grep.app, GitHub repos, or code search results)\n8. Reference implementations documented with repo name, license, and key patterns\n\nScore: X/8. If score < 6, respond with a warning listing which items are missing and suggest the author revise before finalizing. If score >= 6, respond with the score and brief confirmation.",
            "statusMessage": "Scoring research quality..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(src/**/*.ts)|Edit(src/**/*.tsx)|Write(src/**/*.ts)|Write(src/**/*.tsx)",
            "command": "cd \"$PROJECT_DIR\" && npx eslint --fix \"$TOOL_ARG_FILE_PATH\" 2>/dev/null; exit 0",
            "statusMessage": "Auto-formatting..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$PROJECT_DIR\" && BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null); if [[ \"$BRANCH\" != ws/* ]]; then echo \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"SessionStart\\\",\\\"additionalContext\\\":\\\"WARNING: You are on branch [$BRANCH], not a ws/ worksession branch. CLAUDE.md requires running /worksession at session start to create an isolated branch. Invoke /worksession NOW before doing any work.\\\"}}\"; fi",
            "statusMessage": "Checking worksession branch..."
          },
          {
            "type": "command",
            "command": "serena-hooks activate --client=claude-code"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "serena-hooks cleanup --client=claude-code"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/bin/zao-notify.sh"'\"$NOTIFICATION_MESSAGE\"'\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "ZOE_DEFAULT_MODEL": "sonnet",
    "ZOE_HARD_MODEL": "opus",
    "ZOE_QUICK_MODEL": "haiku",
    "PUBLIC_BASE_URL": "https://www.thezao.xyz"
  }
}
