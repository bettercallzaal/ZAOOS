# Portal secrets - NOT committed. Copy to ~/.env.portal on VPS and fill in.
# chmod 600 ~/.env.portal after editing.

# Telegram bot for @zaoclaw_bot (or whatever you rename it to).
# Create via @BotFather on Telegram, /token to rotate.
TELEGRAM_BOT_TOKEN=

# Telegram chat id to send nudges to (your personal DM with the bot).
# Find via: https://api.telegram.org/bot<TOKEN>/getUpdates (send bot a message first)
TELEGRAM_CHAT_ID=

# Basic-auth password for the Caddy forward_auth cookie flow (auth-server.js).
# Currently hardcoded; future: read from here. Plan to move off to CF Access anyway.
PORTAL_PASSWORD=

# Optional: override default ao binary path
# AO_BIN=/home/zaal/.local/bin/ao
