{
  auto_https off
}

# Shared cookie-auth via forward_auth -> auth-server :3005.
(protected) {
  forward_auth localhost:3005 {
    uri /check
    copy_headers Cookie
    @401 status 401
    handle_response @401 {
      reverse_proxy localhost:3005
    }
  }
}

# ao.zaoos.com -> :3002 -> wrapper at /, /app/* proxies to AO :3001
:3002 {
  import protected
  # Body-size cap: AO app proxies uploads; keep generous but bounded (doc 463 finding 5).
  request_body {
    max_size 5MB
  }

  # Terminal mux WebSocket - direct-terminal-ws.js listens on :14801 at path /mux
  @aoWebsocket path /ao-terminal-mux /ao-terminal-mux/*
  handle @aoWebsocket {
    rewrite * /mux
    reverse_proxy localhost:14801
  }

  # AO internal paths (Next.js uses absolute URLs for its own assets)
  @aoAssets path /_next/* /api/* /sessions/* /ws /socket.io/* /__next/*
  handle @aoAssets {
    reverse_proxy localhost:3000
  }

  handle_path /app/* {
    reverse_proxy localhost:3000
  }
  handle_path /app {
    reverse_proxy localhost:3000
  }
  handle {
    root * /home/zaal/caddy/ao
    try_files {path} /index.html
    file_server
  }
}

# portal.zaoos.com -> :3003 -> static portal, /todos UI, backend API
:3003 {
  import protected
  # Body-size cap: portal APIs are small JSON (todos, spawn-agent) — tight cap (doc 463 finding 5).
  request_body {
    max_size 256KB
  }

  @backend path /spawn-action /api/spawn /api/spawn-agent /api/sessions /test-checklist /test-done /api/todos /api/todos/*
  reverse_proxy @backend localhost:3004

  @todosPage path /todos
  handle @todosPage {
    rewrite * /todos.html
    root * /home/zaal/caddy/portal
    file_server
  }

  @agentsPage path /agents
  handle @agentsPage {
    rewrite * /agents.html
    root * /home/zaal/caddy/portal
    file_server
  }

  @actPage path /act
  handle @actPage {
    rewrite * /act.html
    root * /home/zaal/caddy/portal
    file_server
  }

  root * /home/zaal/caddy/portal
  file_server
}

# claude.zaoos.com -> :7682 -> wrapper at /, /terminal/* proxies to ttyd :7681
:7682 {
  import protected
  @term path /terminal/* /terminal
  handle @term {
    uri strip_prefix /terminal
    reverse_proxy localhost:7681
  }
  root * /home/zaal/caddy/claude
  try_files {path} /index.html
  file_server
}

# Auth endpoints (login page, /check, /logout) always accessible
:3006 {
  reverse_proxy localhost:3005
}
